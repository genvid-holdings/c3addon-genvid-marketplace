{
  "name": "c3addon-template",
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@eslint/json": "^0.12.0",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "http-server": "^14.1.1",
    "shx": "^0.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.31.0"
  },
  "scripts": {
    "lint": "eslint src",
    "build": "tsc -p src --outDir dist",
    "postbuild": "shx cp src/*.{json,svg} dist/ && shx mkdir -p dist/lang && shx cp src/lang/*.json dist/lang && shx rm dist/tsconfig.json",
    "watch": "tsc -p src --outDir dist -w",
    "secrets": "op inject -i sample/templates/eos_config.json -o sample/files/eos_config.json -f",
    "devmode": "http-server dist --cors",
    "prezip:windows": "shx rm -f ID_OF_THE_PLUGIN.c3addon",
    "zip:windows": "cd dist && 7z.exe a -tzip -r ..\\ID_OF_THE_PLUGIN.c3addon .",
    "all:windows": "npm run lint && npm run build && npm run zip:windows",
    "prezip:linux": "shx rm -f ID_OF_THE_PLUGIN.c3addon",
    "zip:linux": "cd dist && zip ../ID_OF_THE_PLUGIN.c3addon -r .",
    "all:linux": "npm run lint && npm run build && npm run zip:linux"
  }
}